{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Link",
          "value": "<https://res.cloudinary.com>; rel=preconnect, <https://my-cdn.publicgold.com.my>; rel=preconnect"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.mypublicgold.id" }],
      "destination": "https://mypublicgold.id/:path",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://be-public-gold-indonesia.vercel.app/api/public/sitemap.xml"
    },
    {
      "source": "/:pageid",
      "destination": "https://be-public-gold-indonesia.vercel.app/api/public/render/:pageid"
    },
    {
      "source": "/api-proxy/:match*",
      "destination": "https://publicgold.co.id/:match*"
    },
    {
      "source": "/api-proxy-my/:match*",
      "destination": "https://publicgold.com.my/:match*"
    },
    {
      "source": "/((?!api-proxy|assets|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
