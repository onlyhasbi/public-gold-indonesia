{
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.mypublicgold.id" }],
      "destination": "https://mypublicgold.id/:path",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://be-public-gold-indonesia.vercel.app/api/public/sitemap.xml"
    },
    {
      "source": "/api-proxy/:match*",
      "destination": "https://publicgold.co.id/:match*"
    },
    {
      "source": "/api-proxy-my/:match*",
      "destination": "https://publicgold.com.my/:match*"
    },
    {
      "source": "/((?!api-proxy|assets|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
